#compdef openterminalcli

local -a commands
commands=(
  'help:show command help'
  'status:show GUI or daemon attachment status'
  'version:print version'
  'doctor:diagnose local CLI and profile setup'
  'diagnose:alias for doctor'
  'security:audit local MCP, AI, and network exposure'
  'sec:alias for security'
  'setup:local profile and AI onboarding'
  'onboard:alias for setup'
  'onboarding:alias for setup'
  'demo:one-screen trading system proof'
  'demos:alias for demo'
  'sync:show GUI/daemon/CLI ownership alignment'
  'serve:run or manage a headless daemon'
  'daemon:install or manage the macOS LaunchAgent daemon'
  'service:alias for daemon'
  'launchd:alias for daemon'
  'screens:list openable app screens'
  'open:open a GUI screen'
  'cmd:run command-bar text'
  'actions:list registered app actions'
  'action:invoke an app action'
  'coverage:show CLI parity coverage'
  'profile:view or edit local profile'
  'settings:view or edit local settings'
  'mcp:inspect or call tools'
  'quote:fetch quotes'
  'crypto:crypto venue reads and gated orders'
  'cryptotrade:alias for crypto'
  'ct:alias for crypto'
  'crypto-latency:race public crypto WebSocket feeds'
  'latency:alias for crypto-latency'
  'feed-race:alias for crypto-latency'
  'feedrace:alias for crypto-latency'
  'news:market news'
  'research:equity research'
  'macro:macro and government data'
  'trade:trading accounts and orders'
  'data:data-source connections'
  'agent:local agent registry'
  'workflow:saved workflows'
  'files:File Manager artifacts'
  'notes:research notes'
  'notebook:notebook catalog and runner'
  'notebooks:alias for notebook'
  'nb:alias for notebook'
  'report:Report Builder documents'
  'excel:CSV/XLSX and Google Sheets access'
  'workspace:layouts and panels'
  'notify:notifications'
  'scanner:scanner alert watches'
  'watchlist:watchlists'
  'portfolio:portfolios'
  'edge:stock and prediction-market edge radar'
  'edge-radar:alias for edge'
  'edge_radar:alias for edge'
  'playlist:strategy playlists'
  'playlists:alias for playlist'
  'strategy-playlist:alias for playlist'
  'strategy-playlists:alias for playlist'
  'strategy:trading strategies'
  'strategies:alias for strategy'
  'strat:alias for strategy'
  'hub:DataHub topics'
  'observe:observer journal'
  'ask:LLM prompt'
  'brief:AI market brief'
  'risk:AI risk review'
  'thesis:AI thesis monitor'
  'radar:AI news radar'
  'ai:AI provider and recipe commands'
)

local -a global_opts
global_opts=(
  '--json[print compact JSON]'
  '--headless[run in-process without GUI]'
  '--profile[use local profile]:profile name:'
  '--help[show help]'
)

local curcontext="$curcontext" state line
_arguments -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args'

case $state in
  command)
    _describe -t commands 'openterminalcli command' commands
    ;;
  args)
    case $line[1] in
      help) _describe -t commands 'help topic' commands ;;
      mcp|tools) _values 'mcp subcommand' list search describe call ;;
      security|sec) _values 'security subcommand' network-audit audit net --no-sockets ;;
      demo|demos) _values 'demo subcommand' trading-system system trade-system stack --symbol --crypto-symbol --horizon --market-prob --min-samples BTC BTC/USD 5m 15m 1h daily ;;
      ai) _values 'ai subcommand' providers use test ask brief risk thesis radar recipes recipe run strategy ;;
      news) _values 'news subcommand' latest search status monitors refresh mark-read save unsave ;;
      research) _values 'research subcommand' search quote company overview history financials technicals peers news sentiment filings metrics insiders insider-summary 13f 13f-top politicians health sources source-status feeds find-company resolve gov tool --gaps --limit --period --form --months --quarters --days --force ;;
      macro|econ|economics|dbnomics|govdata|government) _values 'macro subcommand' fred bls calendar cb ons statcan census dbnomics gov econ-run run-econ tool providers datasets series observations search ;;
      trade|trading) _values 'trade subcommand' accounts drafts prepare submit cancel-draft paper live fast audit ;;
      crypto|cryptotrade|ct) _values 'crypto subcommand' info exchange ticker quote q book orderbook depth candles ohlcv bars balance balances funds orders open-orders open fills trades my-trades fees fee tiers coinbase-tiers readiness ready doctor show set reset --venue maker-bps= taker-bps= rebate-pct= free-remaining= free-applies= slippage-bps= profile= buy sell order submit cancel tool --type --limit-price --price --post-only --maker --limit --timeframe --tf --symbol --yes BTC/USD ETH/USD SOL/USD BTC/USDT ETH/USDT SOL/USDT ;;
      data|datasources|ds) _values 'data subcommand' connectors connections get create update delete stats fields test tool lake datalake data-lake status ensure manifest path mirror-edge mirror-decisions mirror-broker-events kalshi decisions broker-events query --symbol --family --horizon --call --account --tool --decision --limit --sql --csv BTC crypto event 5m 15m 1h 1d ;;
      files|file) _values 'files subcommand' list search info read path import write download delete stats storage ;;
      notes|note) _values 'notes subcommand' list search show create update favorite archive delete export ;;
      notebook|notebooks|nb) _values 'notebook subcommand' list ls show info path seed open create new run --category --difficulty --query --force --markdown --code --from-file --open --no-open --cell ;;
      report|reports) _values 'report subcommand' state types templates add bulk update remove move clear metadata theme template save load undo redo tool ;;
      excel|xl|spreadsheet|spreadsheets) _values 'excel subcommand' read write append clear google-read google-write google-append google-clear ;;
      workspace|layout|layouts) _values 'workspace subcommand' layouts recent show export import delete rename templates template apply panels screens open tab add replace ;;
      notify|notification|notifications) _values 'notify subcommand' providers status config set clear enable disable triggers send test ;;
      scanner|scan|alerts) _values 'scanner subcommand' list show add events delete enable disable ;;
      watchlist|wl) _values 'watchlist subcommand' list show create delete add remove lookup ;;
      portfolio|port) _values 'portfolio subcommand' list show create delete assets add sell remove tx dividend split delete-tx snapshots ;;
      edge|edge-radar|edge_radar) _values 'edge subcommand' evaluate score microstructure micro btc-microstructure tape scalp-gate scalp scalping intraday-gate daytrade-gate spot-swing-gate swing-gate spot-gate crypto-swing spot-swing crypto-recommend crypto-recommendation recommend-crypto buy-signal crypto-universe crypto-universe-recommend universe-crypto crypto-breadth decision-cockpit trade-cockpit combined-cockpit signal-cockpit context public-context evidence-context catalysts kalshi-scan kalshi_scan scan-kalshi research explain kalshi-research snapshot-kalshi kalshi-snapshot kalshi-snapshots journal-kalshi-scan kalshi-journal-scan kalshi-decisions impulse btc-impulse btc5m btc-5m polymarket-btc5m btc5m-live btc-5m-live polymarket-btc5m-live snapshot-btc5m-live btc5m-snapshot polymarket-btc5m-snapshot crypto-hourly crypto-hourly-live hourly-live live-crypto-hourly hourly-crypto btc-anchor observe observation record train fit model models model-status probability prob predict gate meta-gate decision publish-horizons publish-outputs publish-all horizon-publish journal decisions decision-journal journal-evaluate-btc5m-live journal-btc5m-live write-btc5m-decision evaluate-btc5m-live stats summary crypto-stats crypto-accuracy crypto-table scorecard-crypto evidence paper-sim simulate proof-loop proof scorekeeping scoreboard trust trust-score regimes regime no-trade do-nothing rare-alerts alerts replay resolve why-no-trade why_no_trade no-trade readiness backfill backfill-crypto import-history collect harvest ticks cockpit dashboard terminal selftest-leakage leakage-test no-lookahead-test add create list ls show get update close remove delete rm --category --family --timeout-ms --duration-ms --sources --symbols --venue --horizon --horizon-sec --fee-bps --slippage-bps --safety-bps --min-profit-bps --minimum-profit-bps --min-edge-bps --max-symbols --window --min-confidence --direction --btc-prob --market --limit --save-candidates --min-edge --strong-edge --min-anchor -