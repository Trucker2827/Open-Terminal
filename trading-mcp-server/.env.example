# Server mode
TRADING_MODE=paper                 # paper | live
DRY_RUN=true                       # true blocks real order placement
REQUIRE_CONFIRMATION=true          # require confirmation_token for trade calls
CONFIRMATION_TOKEN=I_UNDERSTAND_LIVE_TRADE
RATE_LIMIT_PER_MIN=30
LOG_LEVEL=INFO

# Transport safety: stdio is the default and needs no flag. A network transport
# (sse/streamable-http) is REFUSED unless you opt in here AND bind 127.0.0.1.
# Never expose a trading server publicly without auth + firewall + HTTPS.
# TRADING_MCP_ALLOW_HTTP=false

# Risk limits
MAX_ORDER_NOTIONAL_USD=500
MAX_POSITION_NOTIONAL_USD=2500
MAX_DAILY_ORDER_COUNT=25
ALLOW_OPTIONS_TRADING=false
ALLOW_CRYPTO_WITHDRAWALS=false

# Alpaca
ENABLE_ALPACA=true
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_PAPER=true
# Optional override URLs. Usually leave blank for alpaca-py defaults.
ALPACA_BASE_URL=

# Coinbase Advanced Trade
ENABLE_COINBASE=true               # data/reads/dry-run previews (safe to leave on)
# Coinbase has NO paper mode — it's a real account. Reads + dry-run previews always
# work; a REAL order requires DRY_RUN=false AND COINBASE_ALLOW_TRADING=true. Keep this
# OFF at rest; arm it deliberately for a live crypto session, then turn it back off.
COINBASE_ALLOW_TRADING=false
# When armed, ONLY these symbols may execute real orders (comma-separated, any case).
# Fail-closed: empty = nothing may execute. Previews work for any symbol regardless.
COINBASE_ALLOWED_SYMBOLS=BTC-USD,ETH-USD,SOL-USD
COINBASE_API_KEY=organizations/your-org/apiKeys/your-key-id
# Store multiline EC private keys with literal \n sequences in your local .env.
# Do not paste a real private key into this example file.
COINBASE_API_SECRET=your_coinbase_ec_private_key_with_literal_newlines

# Kraken Spot Trading API
ENABLE_KRAKEN=false                # data/reads/dry-run previews when true
# Kraken Spot API keys can cover spot & margin in the UI. This server still
# forces spot limit post-only orders and never sends leverage/margin params.
KRAKEN_ALLOW_TRADING=false
# Fail-closed: empty = nothing may execute. Common symbols are normalized.
KRAKEN_ALLOWED_SYMBOLS=XBTUSD,ETHUSD,SOLUSD
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_private_key_here
